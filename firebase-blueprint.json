{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the CampusMatch AI application.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "lastSession": { "type": "string", "format": "date-time", "description": "When the user last started a session." }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "A saved college recommendation session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this session." },
        "conversationHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" }
            },
            "required": ["role", "content"]
          }
        },
        "studentStory": { "type": "string", "description": "The AI-generated student story." },
        "collegeList": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "tier": { "type": "string", "enum": ["dream", "reach", "match", "safety"] },
              "reason": { "type": "string" },
              "deepDive": { "type": "object" }
            },
            "required": ["name", "tier", "reason"]
          }
        },
        "roadmap": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rightNow": {
          "type": "array",
          "items": { "type": "string" }
        },
        "checklistState": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the session was saved." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the session was last updated." }
      },
      "required": ["userId", "conversationHistory", "studentStory", "collegeList", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Stores saved college recommendation sessions."
    }
  }
}
